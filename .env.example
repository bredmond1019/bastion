# PostgreSQL connection for the Python orchestrator's database (read-only observer).
DATABASE_URL=postgres://<DB_USER>:<DB_PASSWORD>@localhost:5432/orchestration_dev
# Base URL of the orchestrator's FastAPI service.
BASTION_API_URL=http://localhost:8080
# Polling interval in seconds for the live monitor (Phase 1+).
BASTION_POLL_INTERVAL=2
#
# Budget caps (BA.7.C) — both optional. Absent means no gate/alert applies; behavior is
# unchanged from before the v1.1.0 data contract. A present-but-unparseable value is a
# fatal config error, never a silent default.
# BASTION_MAX_TOTAL_TOKENS=1000000
# BASTION_MAX_COST_USD=25.00
#
# X-API-Key secret for the engine's abort endpoint (BA.7.C). Distinct from
# BASTION_SERVE_TOKEN (bastion serve's own Bearer token, see docs/config.md) — two
# different secrets, two different schemes, two different route groups. Required only
# once `bastion abort` / the embedded engine routes are used.
# BASTION_ENGINE_API_KEY=<engine-api-key>
#
# Optional config file: ~/.config/bastion/config.toml (or $XDG_CONFIG_HOME/bastion/config.toml)
# Env vars above always take precedence over the config file. A missing or unreadable config
# file is silently ignored. See docs/config.md for the full reference and an example file.
